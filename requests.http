@BASE_URL = http://localhost:8080

### Create subscriber
POST {{BASE_URL}}/api/subscribers
Content-Type: application/json

{
  "email": "john.doe@example.com"
}

### Create publication
POST {{BASE_URL}}/api/publications
Content-Type: application/json

{
  "title": "04. Integration Testing Application Modules",
  "content": "Spring Modulith - Integration Testing Application Modules"
}

### Get publication by id
GET {{BASE_URL}}/api/publications/1
Accept: application/json
